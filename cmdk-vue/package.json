{
  "name": "cmdk-vue",
  "version": "1.0.0",
  "description": "Fast, composable, unstyled command menu for Vue 3. A faithful port of cmdk by Paco Coursey.",
  "keywords": [
    "vue",
    "vue3",
    "command",
    "command-menu",
    "cmdk",
    "combobox",
    "accessible",
    "headless",
    "unstyled",
    "palette"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "prepublishOnly": "cp ../README.md . && pnpm build",
    "postpublish": "rm README.md",
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "dependencies": {
    "reka-ui": "^2.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krushndayshmookh/cmdk-vue.git",
    "directory": "cmdk-vue"
  },
  "bugs": {
    "url": "https://github.com/krushndayshmookh/cmdk-vue/issues"
  },
  "homepage": "https://github.com/krushndayshmookh/cmdk-vue#readme",
  "author": {
    "name": "Krushn Dayshmookh",
    "url": "https://github.com/krushndayshmookh"
  }
}
